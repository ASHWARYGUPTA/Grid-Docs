# Production env for Vercel deploys — these are NEXT_PUBLIC_* values, inlined
# into the client bundle at build time (not secrets), so this file is safe to
# commit. Vercel automatically loads .env.production for `next build` when
# no Project Settings env var of the same name overrides it.
#
# NEXT_PUBLIC_MAPPLS_KEY is domain-whitelisted server-side by Mappls and must
# be set in the Vercel dashboard (Project Settings -> Environment Variables)
# instead, since the whitelisted domain has to match the deployed Vercel URL.

NEXT_PUBLIC_API_URL=https://grid-docs.onrender.com
NEXT_PUBLIC_WS_URL=wss://grid-docs.onrender.com/ws/dashboard
