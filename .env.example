# Copy to .env and adjust for local bare-metal runs.
# Docker Compose sets these automatically for the api service.

# Database — use Postgres in Docker, SQLite for bare-metal dev
GRID_DATABASE_URL=postgresql+asyncpg://grid:grid@localhost:5432/grid_unlocked
# GRID_DATABASE_URL=sqlite+aiosqlite:///./grid_unlocked.db

# Redis — feature cache (M02+) and future event bus
GRID_REDIS_URL=redis://localhost:6379/0

# ASTraM training corpus path
GRID_ASTRAM_CSV_PATH=../data/astram_events.csv

# M15 — frontend origins allowed to call the API + WebSocket (CORS), JSON list.
# Required when the frontend is hosted on a separate domain (e.g. Vercel) —
# the default only allows localhost:3000. Set this on the backend host
# (Render, etc.), not in the frontend's own env. Example:
# GRID_CORS_ALLOW_ORIGINS=["https://your-project.vercel.app"]
GRID_CORS_ALLOW_ORIGINS=

# Frontend (M15 CommandDashboard) — shared with the frontend service in Docker Compose.
# For a Vercel deploy, set these instead in frontend/.env.production (already
# pointed at the hosted backend) or override per-environment in the Vercel
# dashboard.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/dashboard

# Free MapTiler API key — https://www.maptiler.com/cloud/ (100k tile loads/month free)
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key_here

# Mappls (MapMyIndia) static web key — https://auth.mappls.com/console/
# Domain whitelist must be a real domain.tld shape; "localhost" alone is
# rejected by Mappls' validator, use a hosts-file alias for local dev.
NEXT_PUBLIC_MAPPLS_KEY=your_mappls_key_here
